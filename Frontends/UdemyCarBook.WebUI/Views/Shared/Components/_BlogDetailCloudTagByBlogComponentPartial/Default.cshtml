@model List<UdemyCarBook.Dto.TagCloudDtos.GetByBlogIdTagCloudDto>
<div class="tag-widget post-tag-container mb-5 mt-5">
    <div class="tagcloud">
        @foreach (var item in Model)
        {
            <a href="/Blog/BlogDetail/?id=@item.BlogID" class="tag-cloud-link">@item.Title</a>
        }
        
       
    </div>
</div>