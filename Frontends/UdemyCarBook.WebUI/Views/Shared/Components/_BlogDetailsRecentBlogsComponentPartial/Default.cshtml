@model List<ResultLast3BlogsWithAuthors>

<div class="sidebar-box ftco-animate">
    <h3>Son Boglar</h3>
    @foreach (var item in Model)
    {
        <div class="block-21 mb-4 d-flex">
            <a href="/Blog/BlogDetail/?id=@item.BlogID" class="blog-img mr-4" style="background-image: url('@item.CoverImageUrl');"></a>
            <div class="text">
                <h3 class="heading"><a href="/Blog/Index/?id=@item.BlogID">@item.Title</a></h3>
                <div class="meta">
                    <div><a href="/Blog/BlogDetail/?id=@item.BlogID"><span class="icon-calendar"></span>@item.CreatedDate</a></div>
                    <div><a href="/Blog/BlogDetail/?id=@item.BlogID"><span class="icon-person"></span> @item.AuthorName</a></div>
                    <div><a href="/Blog/BlogDetail/?id=@item.BlogID"><span class="icon-chat"></span>0</a></div>
                </div>
            </div>
        </div>
    }
</div>
